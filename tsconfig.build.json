{
  "compilerOptions": {
    "target":                     "ES2020",
    "module":                     "ESNext",
    "moduleResolution":           "Bundler",
    "lib":                        ["ES2020", "DOM", "DOM.Iterable"],
    "strict":                     true,
    "skipLibCheck":               true,
    "allowJs":                    false,
    "declaration":                true,
    "emitDeclarationOnly":        true,
    "declarationDir":             "./dist",
    "noEmit":                     false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "bin/**", "test/**"]
}
