{
  "name": "@canister-software/consensus-cli",
  "version": "0.1.0-beta.6",
  "description": "Consensus SDK for interacting with the Consensus protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun":     "./src/index.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    },
    "./cli": "./bin/consensus.ts"
  },
  "bin": {
    "consensus": "./bin/consensus.ts"
  },
  "scripts": {
    "clean":       "rm -rf dist",
    "build":       "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types",
    "build:esm":   "bun build src/index.ts --outfile dist/index.js  --format esm --target node --packages=external",
    "build:cjs":   "bun build src/index.ts --outfile dist/index.cjs --format cjs --target node --packages=external",
    "build:types": "tsc -p tsconfig.build.json",
    "consensus": "bun bin/consensus.ts",
    "setup": "bun bin/consensus.ts setup",
    "reset": "bun bin/consensus.ts setup --force",
    "startproxyserver": "bun test/proxy/server.ts"
  },
  "dependencies": {
    "@canister-software/x402-icp": "^0.1.1",
    "@coinbase/cdp-sdk": "^1.25.0",
    "@opentui/core": "^0.1.90",
    "@scure/base": "^2.0.0",
    "@solana/signers": "^5.3.0",
    "@x402/core": "^2.1.0",
    "@x402/evm": "^2.1.0",
    "@x402/fetch": "^2.1.0",
    "@x402/svm": "^2.1.0",
    "chalk": "^5.4.1",
    "inquirer": "^9.2.15",
    "ora": "^8.2.0",
    "viem": "^2.31.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/ws": "^8.18.1",
    "@types/node": "^20.0.0",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "consensus",
    "api",
    "deduplication",
    "x402",
    "payments",
    "HTTPS",
    "cli"
  ],
  "author": "Demali Gregg",
  "license": "MIT",
  "engines": {
    "bun":  ">=1.3.0",
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "bin/",
    "dist/",
    "README.md",
    "LICENSE",
    "assets/"
  ]
}
